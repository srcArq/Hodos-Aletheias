# Normalize text line endings on checkin
* text=auto eol=lf

# Windows batch scripts must keep CRLF
*.bat text eol=crlf

# The Unix Gradle wrapper script must stay LF
gradlew text eol=lf

# Binary assets — never normalize or diff
*.png  binary
*.jpg  binary
*.jpeg binary
*.wav  binary
*.mp3  binary
*.ogg  binary
*.apk  binary
*.jar  binary
*.so   binary
